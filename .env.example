# Voice help agent environment variables

# Knowledge base
VEELEAD_URL=https://veelead-rag.southeastasia.cloudapp.azure.com/search.json
VEELEAD_API_KEY=

# Local LLM via Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
