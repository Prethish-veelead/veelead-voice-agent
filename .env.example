OLLAMA_MODEL=llama3.2

# Local Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=

# Local TTS
LOCAL_TTS_BACKEND=piper
PIPER_BIN=piper
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_SPEAKER_WAV=
XTTS_LANGUAGE=en

# Existing cloud/telephony settings kept for compatibility
OPENAI_API_KEY=
GPT_ENDPOINT=
GPT_API_KEY=
